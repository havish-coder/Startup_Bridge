# ── Setup instructions for new teammates ──────────────────────────────────────
#
# 1. Copy this file:        cp .env.example .env
# 2. Fill in JWT_SECRET:    paste the value shared by the team over WhatsApp/Discord
# 3. Leave everything else as-is — it already matches docker-compose.yml
#
# ──────────────────────────────────────────────────────────────────────────────

NODE_ENV=development
PORT=4000

# Matches docker-compose.yml exactly — no changes needed
DATABASE_URL=postgresql://postgres:postgres123@127.0.0.1:5432/startupbridge

# THE ONLY THING YOU NEED TO FILL IN:
# Paste the JWT_SECRET value shared by your team (WhatsApp/Discord)
# Generate a new one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=
JWT_EXPIRY=7d

FRONTEND_URL=http://localhost:5173
ADMIN_CONTACT_PHONE=+91-XXXXXXXXXX

# File storage — leave blank in local dev (uses local disk)
# In production: sign up at cloudinary.com, paste these from your dashboard
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
